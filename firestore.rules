rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Challenge Configuration Root Collection
    match /challenges/{challengeId} {
      allow read, write: if true;
    }

    // Subcollection for specific Movie Topics inside a challenge
    match /challenges/{challengeId}/topics/{topicId} {
      allow read, write: if true;
    }

    // Application Global Settings and Passwords
    match /settings/{settingsId} {
      allow read, write: if true;
    }
  }
}
